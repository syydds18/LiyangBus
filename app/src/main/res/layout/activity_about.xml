<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mi_bg"
    android:orientation="vertical">

    <!-- Title Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/mi_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="返回"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/mi_text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="关于"
            android:textColor="@color/mi_text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="32dp"
            android:paddingHorizontal="24dp"
            android:paddingBottom="32dp">

            <!-- App Icon -->
            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@mipmap/ic_launcher"
                android:contentDescription="应用图标" />

            <!-- App Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="溧阳公交"
                android:textColor="@color/mi_text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- Version -->
            <TextView
                android:id="@+id/tvVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="v1.8.1"
                android:textColor="@color/mi_text_secondary"
                android:textSize="14sp" />

            <!-- App Description -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="应用简介"
                    android:textColor="@color/mi_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"
                    android:text="溧阳公交实时查询工具，数据来源于溧阳公交官方API。支持多种查询方式，帮助您更方便地乘坐公交出行。"
                    android:textColor="@color/mi_text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Main Features -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔍 搜索功能"
                    android:textColor="@color/mi_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"
                    android:text="• 输入线路号搜索（如：101、221）\n• 输入站名搜索（如：汽车站、燕山）\n• 支持模糊搜索\n• 枢纽站名称显示为橙色，方便识别重要换乘点"
                    android:textColor="@color/mi_text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Realtime Features -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚌 实时查询"
                    android:textColor="@color/mi_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"
                    android:text="• 公交实时位置显示\n• 距离本站还有几站\n• 车辆拥挤程度显示\n• 首末班时间查询\n• 票价信息\n• 长按时刻表中的发车时间，可查看对应车牌号"
                    android:textColor="@color/mi_text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Favorites Features -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐ 收藏功能"
                    android:textColor="@color/mi_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"
                    android:text="• 长按搜索结果收藏线路\n• 首页显示收藏线路实时状态\n• 10秒自动刷新\n• 支持设置默认方向\n• 同方向多辆车同时显示"
                    android:textColor="@color/mi_text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Transfer Features -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔄 换乘查询"
                    android:textColor="@color/mi_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"
                    android:text="• 支持1-2次换乘\n• 自动规划最优路线\n• 显示换乘站点和线路\n• 右上角菜单进入"
                    android:textColor="@color/mi_text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Alert Features -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔔 到站提醒"
                    android:textColor="@color/mi_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"
                    android:text="• 悬浮窗提醒（最醒目）\n• 通知栏提醒\n• 强震动提醒（3次震动）\n• 支持设置提醒距离（1-3站）\n• 长按🔔按钮设置"
                    android:textColor="@color/mi_text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Other Features -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 其他功能"
                    android:textColor="@color/mi_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"
                    android:text="• 附近站点自动定位\n• 地图查看站点位置\n• 长按站点名称查询经过该站点的所有线路\n• 运行日志查看（长按标题）\n• 深色模式自动适配\n• 下拉刷新"
                    android:textColor="@color/mi_text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Data Source -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="数据来源"
                    android:textColor="@color/mi_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="溧阳公交官方数据平台\nhttps://www.ly-xing.com"
                    android:textColor="@color/mi_text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
