<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mi_bg"
    android:orientation="vertical">

    <!-- Title Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/mi_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="返回"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/mi_text_primary" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="线路详情"
            android:textColor="@color/mi_text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnFavorite"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="☆"
            android:textSize="18sp"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/btnMap"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="4dp"
            android:gravity="center"
            android:text="🗺️"
            android:textSize="18sp"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <TextView
            android:id="@+id/btnReminder"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="8dp"
            android:gravity="center"
            android:text="🔕"
            android:textSize="18sp"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <TextView
            android:id="@+id/btnShare"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="4dp"
            android:gravity="center"
            android:text="↗"
            android:textColor="@color/mi_orange"
            android:textSize="20sp"
            android:textStyle="bold"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <TextView
            android:id="@+id/btnDirection"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/btn_primary"
            android:gravity="center"
            android:paddingHorizontal="14dp"
            android:text="切换方向"
            android:textColor="@android:color/white"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- FrameLayout to overlay floating buttons -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ScrollView
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- Info Bar -->
                <LinearLayout
                    android:id="@+id/cardInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_bg"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/tvDirection"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/mi_orange"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:background="?attr/selectableItemBackground"
                        android:paddingHorizontal="4dp"
                        android:paddingVertical="2dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="首班: "
                            android:textColor="@color/mi_text_secondary"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvFirstTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/mi_text_primary"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="末班: "
                            android:textColor="@color/mi_text_secondary"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvLastTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/mi_text_primary"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="票价: "
                            android:textColor="@color/mi_text_secondary"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/mi_orange"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvVehicleAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:textColor="@color/mi_text_secondary"
                            android:textSize="13sp"
                            android:visibility="gone" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/btnSchedule"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="🕐 时刻表"
                        android:textColor="@color/mi_orange"
                        android:textSize="13sp"
                        android:background="?attr/selectableItemBackground"
                        android:paddingHorizontal="4dp"
                        android:paddingVertical="2dp" />
                </LinearLayout>

                <!-- Nearest Bus Card -->
                <LinearLayout
                    android:id="@+id/cardNearestBus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/card_bg"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🚌 最近一班"
                        android:textColor="@color/mi_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvNearestDistance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/mi_orange"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvNearestStations"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:textColor="@color/mi_text_secondary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvComfort"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Loading / Error -->
                <LinearLayout
                    android:id="@+id/layoutLoading"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="32dp">

                    <ProgressBar
                        android:id="@+id/progressLoading"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:indeterminateTint="@color/mi_orange" />

                    <TextView
                        android:id="@+id/tvLoadingText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="加载中..."
                        android:textColor="@color/mi_text_secondary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/btnDetailRetry"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/btn_secondary"
                        android:gravity="center"
                        android:paddingHorizontal="32dp"
                        android:text="点击重试"
                        android:textColor="@color/mi_orange"
                        android:textSize="14sp"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- Station List -->
                <LinearLayout
                    android:id="@+id/layoutStations"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/card_bg"
                    android:orientation="vertical"
                    android:padding="4dp" />

            </LinearLayout>
        </ScrollView>

        <!-- Floating Jump Buttons -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="16dp"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/btnJumpDown"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/circle_fab_orange"
                android:gravity="center"
                android:text="▼"
                android:textColor="@android:color/white"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/btnJumpUp"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/circle_fab_outline"
                android:gravity="center"
                android:text="▲"
                android:textColor="@color/mi_orange"
                android:textSize="16sp" />
        </LinearLayout>

    </FrameLayout>
</LinearLayout>
